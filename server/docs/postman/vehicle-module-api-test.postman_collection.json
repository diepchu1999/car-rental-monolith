              "query": []
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"COMPANY_OWNED\",\n  \"ownerCustomerId\": null,\n  \"fleetVehicleId\": \"{{fleetVehicleId}}\",\n  \"brand\": \"Ford\",\n  \"model\": \"Transit\",\n  \"version\": \"Postman Fleet Test\",\n  \"manufactureYear\": 2023,\n  \"licensePlate\": \"{{testLicensePlate}}\",\n  \"seats\": 16,\n  \"transmission\": \"MANUAL\",\n  \"fuelType\": \"DIESEL\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Dùng {{fleetVehicleId}} từ Setup. Lưu ý nếu backend chưa sync fleet.company_vehicles.vehicle_id theo vehicle mới thì detail/list có thể chưa hiện asset/branch."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set(\"testLicensePlate\", \"CMP-\" + Date.now().toString().slice(-8));"
