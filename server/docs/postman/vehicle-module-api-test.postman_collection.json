          "name": "Search customers - save hostCustomerId",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/customers/search?q=&page=1&size=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "customers",
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "",
                  "disabled": false
                },
                {
                  "key": "page",
                  "value": "1",
                  "disabled": false
                },
                {
                  "key": "size",
                  "value": "20",
                  "disabled": false
                }
              ]
            },
            "description": "Lấy customer đầu tiên để dùng cho create HOST_OWNED. Nếu muốn host cụ thể, sửa query q."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 2xx\", function () {",
                  "  pm.expect(pm.response.code).to.be.within(200, 299);",
                  "});",
                  "const json = pm.response.json();",
                  "const items = json?.data?.items || json?.data?.data?.items || json?.data?.items || [];",
                  "if (items.length && items[0].id) pm.collectionVariables.set(\"hostCustomerId\", items[0].id);",
                  "console.log(\"hostCustomerId\", pm.collectionVariables.get(\"hostCustomerId\"));"
                ]
              }
            }
          ]
