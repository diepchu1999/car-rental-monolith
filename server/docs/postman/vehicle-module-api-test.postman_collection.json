    {
      "name": "02 - Create vehicle",
      "item": [
        {
          "name": "Create HOST_OWNED vehicle",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/vehicles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "vehicles"
              ],
              "query": []
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"HOST_OWNED\",\n  \"ownerCustomerId\": \"{{hostCustomerId}}\",\n  \"fleetVehicleId\": null,\n  \"brand\": \"Toyota\",\n  \"model\": \"Vios\",\n  \"version\": \"Postman Test\",\n  \"manufactureYear\": 2024,\n  \"licensePlate\": \"{{testLicensePlate}}\",\n  \"seats\": 5,\n  \"transmission\": \"AUTOMATIC\",\n  \"fuelType\": \"GASOLINE\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Chạy Setup trước để có {{hostCustomerId}}. Request này tự sinh biển số TEST-*."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set(\"testLicensePlate\", \"TEST-\" + Date.now().toString().slice(-8));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 2xx\", function () {",
                  "  pm.expect(pm.response.code).to.be.within(200, 299);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json?.data?.id) { pm.collectionVariables.set(\"createdVehicleId\", json.data.id); pm.collectionVariables.set(\"vehicleId\", json.data.id); }",
                  "console.log(\"createdVehicleId\", pm.collectionVariables.get(\"createdVehicleId\"));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create COMPANY_OWNED vehicle",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/vehicles",
              "host": [
                "{{baseUrl}}"
